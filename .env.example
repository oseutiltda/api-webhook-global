# ==============================
# Ambiente local - Global (PostgreSQL)
# ==============================

# PostgreSQL local
POSTGRES_DB=global_integrador
POSTGRES_USER=global
POSTGRES_PASSWORD=global123
POSTGRES_PORT=5432

# URL usada por backend e worker
DATABASE_URL=postgresql://global:global123@localhost:5432/global_integrador?schema=public

# Backend
NODE_ENV=development
PORT=3000
WEBHOOK_SECRET=ALTERE_ESTE_SEGREDO
API_FIXED_TOKEN=ALTERE_TOKEN_FIXO_DAS_ROTAS
ADMIN_SEED_LOGIN=afs@afs
ADMIN_SEED_PASSWORD=afs123
ADMIN_SEED_ROLE=ADMIN
# Opcional por rota (se vazio usa API_FIXED_TOKEN):
# NFSE_FIXED_TOKEN=
# CIOT_FIXED_TOKEN=
# CTE_FIXED_TOKEN=
# PESSOA_FIXED_TOKEN=
# CONTAS_PAGAR_FIXED_TOKEN=
# CONTAS_RECEBER_FIXED_TOKEN=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN1_USER=afs@afs
NEXT_PUBLIC_ADMIN1_PASSWORD=afs123
NEXT_PUBLIC_ADMIN2_USER=admin2@admin
NEXT_PUBLIC_ADMIN2_PASSWORD=admin2#change-me

# Worker
WORKER_INTERVAL_MS=5000
WORKER_BATCH_SIZE=10
WORKER_MAX_RETRIES=3
ENABLE_WORKER=true
LOG_LEVEL=info
CIOT_WORKER_BATCH_SIZE=3

# Flags de migracao / operacao segura
ENABLE_EXTERNAL_EXPORT=false
ENABLE_EXTERNAL_IMPORT=false
ENABLE_SENIOR_INTEGRATION=false
ENABLE_DASHBOARD_DATA=false
ENABLE_SQLSERVER_LEGACY=false
ENABLED_WORKER_SERVICES=

# Mantidos por compatibilidade (legado)
SENIOR_DATABASE=SOFTRAN_BRASILMAXI
NFSE_DESTINATION_DATABASE=SOFTRAN_BRASILMAXI_HML
NFSE_SOURCE_DATABASE=AFS_INTEGRADOR
CIOT_SOURCE_DATABASE=AFS_INTEGRADOR
