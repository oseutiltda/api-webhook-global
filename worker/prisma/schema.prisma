generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// WebhookEvent com status de processamento
model WebhookEvent {
  id         String   @id
  source     String
  receivedAt DateTime @default(now())
  status     String?  @default("pending") // pending, processing, processed, failed
  processedAt DateTime?
  errorMessage String? @db.VarChar(1000)
  retryCount Int      @default(0)
  
  // Novos campos para monitoramento de integração
  integrationStatus String? @db.VarChar(50) // pending, integrated, failed, skipped
  processingTimeMs  Int?    // Tempo de processamento em milissegundos
  integrationTimeMs Int?    // Tempo de integração com Senior em milissegundos
  seniorId          String? @db.VarChar(255) // ID gerado na Senior (ex: nrFatura, cdCartaFrete)
  metadata          String? @db.VarChar(2000) // JSON com informações adicionais
  tipoIntegracao    String? @db.VarChar(50) // Web API, Worker - identifica de qual serviço é o evento
  
  @@index([status])
  @@index([receivedAt])
  @@index([integrationStatus])
  @@index([source])
  @@index([tipoIntegracao])
}

// Tabelas STAGING (intermediárias do backend)
// Tabela intermediária para CT-e (backend insere aqui, worker processa)
model Cte {
  id                  Int       @id @default(autoincrement())
  external_id         Int
  authorization_number Int
  status              String    @db.VarChar(50)
  xml                 String    @db.Text
  event_xml           String?   @db.Text
  processed           Boolean   @default(false)
  created_at          DateTime  @default(now()) @db.Timestamp(3)
  updated_at          DateTime  @updatedAt @db.Timestamp(3)

  @@map("ctes")
  @@index([external_id])
  @@index([authorization_number])
  @@index([status])
  @@index([processed])
}

model CteAutorizado {
  id                   String  @id
  authorizationNumber  Int
  status               String
  xml                  String  @db.VarChar(4000)
  eventXml             String? @db.VarChar(4000)
  chCTe                String? @db.VarChar(60)
