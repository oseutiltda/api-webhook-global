  comentarioFrete      String? @db.VarChar(4000)
  usuarioAlteracao     String?
  dataAlteracao        String?
  dataCancelamento      String?
  motivoCancelamento   String?
  filialCancelamento   String?
  cnpjConsignatario    String?
  cnpjRedespacho       String?
  cnpjExpedidor        String?
  valorBaseCalculoPis  Float?
  aliqPis              Float?
  valorPis             Float?
  aliqCofins           Float?
  valorCofins          Float?
  dataPrazo            String?
  diasEntrega          Int?
  cnpjRemetente        String?
  cepRemetente         String?
  cnpjDestinatario     String?
  cepDestinatario      String?
  logradouroDestinatario String?
  processedAt         DateTime @default(now())
  webhookEventId      String?

  @@index([prestadorCnpj])
  @@index([tomadorCnpj])
  @@index([webhookEventId])
}

model FinalPessoa {
  id                  String   @id
  nomeRazaoSocial     String?
  nomeFantasia        String?
  cpf                 String?
  cnpj                String?
  inscricaoMunicipal  String?
  inscricaoEstadual   String?
  ativo               Boolean?
  dataCadastro        String?
  usuarioCadastro     String?
  payload             String?  @db.VarChar(4000)
  processedAt         DateTime @default(now())
  webhookEventId      String?

  enderecos           FinalPessoaEndereco[]
  
  @@index([webhookEventId])
  @@index([cnpj])
  @@index([cpf])
}

model FinalPessoaEndereco {
  id                     String @id @default(uuid())
  pessoaId               String
  codTipoEndereco        Int
  descricaoTipoEndereco  String?
  cep                    String?
  logradouro             String?
  numero                 String?
  complemento            String?
  bairro                 String?
  cidade                 String?
  estado                 String?

  pessoa                 FinalPessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  @@index([pessoaId])
}

