generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WebhookEvent {
  id         String   @id
  source     String
  receivedAt DateTime @default(now())
  status     String?  @default("pending") // pending, processing, processed, failed
  processedAt DateTime?
  errorMessage String? @db.VarChar(1000)
  retryCount Int      @default(0)
  
  // Novos campos para monitoramento de integração
  integrationStatus String? @db.VarChar(50) // pending, integrated, failed, skipped
  processingTimeMs  Int?    // Tempo de processamento em milissegundos
  integrationTimeMs Int?    // Tempo de integração com Senior em milissegundos
  seniorId          String? @db.VarChar(255) // ID gerado na Senior (ex: nrFatura, cdCartaFrete)
  metadata          String? @db.VarChar(2000) // JSON com informações adicionais
  tipoIntegracao    String? @db.VarChar(50) // Web API, Worker - identifica de qual serviço é o evento
  
  @@index([status])
  @@index([receivedAt])
  @@index([integrationStatus])
  @@index([source])
  @@index([tipoIntegracao])
}

model CteAutorizado {
  id                   String  @id // recebido como number, armazenado como string
  authorizationNumber  Int
  status               String
  xml                  String  @db.VarChar(4000)
  eventXml             String? @db.VarChar(4000)
  // Campos derivados
  chCTe                String? @db.VarChar(60)
  nProt                String? @db.VarChar(60)
  dhEmi                String? @db.VarChar(40)
  dhRecbto             String? @db.VarChar(40)
  serie                String? @db.VarChar(10)
  nCT                  String? @db.VarChar(20)
  emitCnpj             String? @db.VarChar(20)
  destCnpj             String? @db.VarChar(20)
  vTPrest              Float?
  vRec                 Float?

  @@index([chCTe])
  @@index([nProt])
  @@index([emitCnpj])
  @@index([destCnpj])
}

model CteCancelado {
  id                  String  @id
  authorizationNumber Int
  status              String
  xml                 String  @db.VarChar(4000)
  eventXml            String? @db.VarChar(4000)
  // Campos derivados
  chCTe               String? @db.VarChar(60)
  nProt               String? @db.VarChar(60)
  dhRegEvento         String? @db.VarChar(40)
  tpEvento            String? @db.VarChar(20)
  xEvento             String? @db.VarChar(60)
  emitCnpj            String? @db.VarChar(20)

  @@index([chCTe])
  @@index([nProt])
}

